# Copy to .env on the camera unit. These are the per-unit secrets/overrides.

# Identity — must match the serial you registered in the console.
EISENFIEDER_CAMERA__ID=EFS-DEV-0001

# Where to send events, and the pairing token from registration.
BACKEND_URL=http://127.0.0.1:8000
BACKEND_API_TOKEN=

# Turn syncing on (config.yaml has uploader.enabled too).
EISENFIEDER_UPLOADER__ENABLED=true

# Live preview in the console (low frame-rate, lets the owner check framing).
EISENFIEDER_UPLOADER__LIVE_ENABLED=true

# On a real Pi you'd usually pin these:
# EISENFIEDER_SOURCE__BACKEND=picamera2
# EISENFIEDER_DETECTOR__BACKEND=yolo
