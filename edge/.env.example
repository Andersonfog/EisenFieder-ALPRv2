# Copy to .env on the camera machine. These are per-machine secrets/overrides.

# Identity. In local dev, EFS-USB-001 auto-appears in the console when preview starts.
EISENFIEDER_CAMERA__ID=EFS-USB-001

# Where to send events, and the pairing token from registration.
# For local dev, BACKEND_API_TOKEN can stay blank unless you registered this
# exact camera id in the console and generated a token.
BACKEND_URL=http://127.0.0.1:8000
BACKEND_API_TOKEN=

# Turn syncing on.
EISENFIEDER_UPLOADER__ENABLED=true

# Live preview in the console.
EISENFIEDER_UPLOADER__LIVE_ENABLED=true
EISENFIEDER_UPLOADER__LIVE_MODE=stream

# USB laptop/workstation defaults.
EISENFIEDER_SOURCE__BACKEND=usb
EISENFIEDER_SOURCE__USB_INDEX=0
EISENFIEDER_SOURCE__QUALITY_PROFILE=workstation_track
EISENFIEDER_DETECTOR__BACKEND=yolo
