# Copy to .env and fill in real values before going live.

# development | production  (production refuses to boot with weak settings below)
APP_ENV=development

# Shown in the console header.
BUSINESS_NAME=Your Business

# The ONLY human login. Pick a strong password (10+ chars).
OWNER_EMAIL=owner@eisenfieder.local
OWNER_PASSWORD=changeme123

# Random 32+ character secret used to sign login tokens. Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-secret-change-me

# Camera ingest. Leave blank for local dev (open ingest). In production each
# camera uses its own pairing token from registration, so you can leave this blank.
INGEST_TOKEN=

# Where the console runs (comma-separated). Never use "*" in production.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local data
DATABASE_URL=sqlite:///./surveillance.db
MEDIA_DIR=./media

# Privacy: auto-purge records/images older than N days (0 = keep forever).
DATA_RETENTION_DAYS=0

# Text alerts when a watchlisted (banned) plate is seen.
# Without Twilio creds the alert is just logged to the server; fill these in
# (and `pip install twilio`) to send a real SMS to OWNER_PHONE.
ALERTS_ENABLED=true
OWNER_PHONE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
